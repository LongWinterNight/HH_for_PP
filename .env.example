# HH.ru API Configuration
# Замените на ваш email для соблюдения правил HH.ru API
HH_USER_EMAIL=your_email@example.com

# Rate Limiting (задержка между запросами в секундах)
# Рекомендуется не менее 1.0 секунды
API_REQUEST_DELAY=1.0

# Лимиты сбора данных
MAX_PAGES=10
DAYS_BACK=30

# Пути к данным (относительно корня проекта)
DATA_DIR=data
RAW_DATA_DIR=data/raw
PROCESSED_DATA_DIR=data/processed
REPORTS_DIR=data/reports

# База данных
DB_PATH=data/hh_vacancies.db

# Логирование
LOG_LEVEL=INFO
LOG_FILE=logs/hh_analytics.log
