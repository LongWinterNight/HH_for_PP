# ============================================================
# HH.ru Analytics — Production Environment Variables
# ============================================================
# Скопируйте этот файл в .env и заполните значения!
# cp .env.production.example .env
# ============================================================

# ─────────────────────────────────────────────────────────
# HH.ru API Configuration
# ─────────────────────────────────────────────────────────
# ⚠️ ВАЖНО: Укажите email от вашего аккаунта HH.ru!
# Без email парсер не запустится.
HH_USER_EMAIL=your_email@example.com

# Задержка между запросами (секунды)
# Не менее 1.0 — иначе рискуете получить бан от HH API
API_REQUEST_DELAY=1.0

# Лимиты сбора данных
MAX_PAGES=10
DAYS_BACK=30

# ─────────────────────────────────────────────────────────
# PostgreSQL Database
# ─────────────────────────────────────────────────────────
# Для Docker Compose — оставить как есть (переопределяется в docker-compose.yml)
# Для прямого подключения — указать реальный URL
DATABASE_URL=postgresql+psycopg2://hh_user:POSTGRES_PASSWORD@postgres:5432/hh_analytics

# Пароль для PostgreSQL (используется в docker-compose.yml)
# ⚠️ Измените на сложный пароль для продакшена!
POSTGRES_PASSWORD=ChangeMe_InProduction_2026!

# ─────────────────────────────────────────────────────────
# Пути к данным (внутри контейнера)
# ─────────────────────────────────────────────────────────
DATA_DIR=/app/data
RAW_DATA_DIR=/app/data/raw
PROCESSED_DATA_DIR=/app/data/processed
REPORTS_DIR=/app/data/reports

# База данных (для fallback на SQLite, если PostgreSQL недоступен)
DB_PATH=/app/data/hh_vacancies.db

# ─────────────────────────────────────────────────────────
# Логирование
# ─────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=/app/logs/hh_analytics.log

# ─────────────────────────────────────────────────────────
# Домен и SSL (для Caddy)
# ─────────────────────────────────────────────────────────
# Замените на ваш реальный домен
APP_DOMAIN=hh-analytics.example.com
